{
  "name": "axiony-web",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "prepare": "cd .. && web/node_modules/.bin/husky",
    "postinstall": "prisma generate",
    "predev": "npm --prefix ../cli run build",
    "dev": "next dev",
    "prebuild": "npm --prefix ../cli run build",
    "build": "next build --webpack",
    "build:web": "next build --webpack",
    "prestart": "npm --prefix ../cli run build",
    "start": "next start",
    "db:check": "node --env-file=.env scripts/db-check.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "type-check": "tsc --noEmit",
    "verify": "npm run lint && npm run format:check && npm run type-check && npm run build:web"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-auth": "^1.6.20",
    "classnames": "^2.5.1",
    "next": "^16.2.7",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.7",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "sass": "^1.77.8",
    "typescript": "^5.5.3"
  }
}
