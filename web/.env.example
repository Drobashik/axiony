# Runtime database URL. Use Neon's pooled endpoint in production.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# Direct database URL for Prisma migrations/introspection. Use Neon's unpooled endpoint.
# If omitted in CI/build-only contexts, prisma.config.ts falls back to DATABASE_URL.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# BetterAuth secret used for signing/encryption. Generate with:
# openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-random-secret"

# Canonical production origin. Do not set this to a single Vercel Preview URL.
BETTER_AUTH_URL="https://example.com"

# Extra hosts BetterAuth may resolve dynamically, useful for Vercel Preview deployments.
# Keep *.vercel.app for standard Vercel preview URLs, or replace/add your preview suffix.
BETTER_AUTH_ALLOWED_HOSTS="*.vercel.app"

# Optional remote scanner service URL used by Vercel deployments.
# AXIONY_SCANNER_API_URL="https://scanner.example.com"
