{
  "name": "axiony",
  "version": "0.1.0-alpha.0",
  "description": "Early alpha CLI for scanning web pages for accessibility issues with axe-core.",
  "bin": {
    "axiony": "./dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "ts-node src/index.ts",
    "prebuild": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "tsc",
    "start": "node dist/index.js",
    "prepack": "npm run build",
    "lint": "eslint src",
    "prettier": "prettier --write ."
  },
  "keywords": [
    "accessibility",
    "a11y",
    "cli",
    "axe-core",
    "playwright",
    "accessibility-testing",
    "wcag",
    "audit",
    "scanner",
    "testing",
    "web"
  ],
  "author": "",
  "license": "MIT",
  "lint-staged": {
    "**/*.{ts,js}": [
      "eslint",
      "prettier --write"
    ],
    "**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "axe-core": "^4.9.1",
    "commander": "^12.0.0",
    "playwright": "^1.59.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.58.1"
  }
}
